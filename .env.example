# URL du projet, disponible dans Paramètres > API dans Supabase
VITE_SUPABASE_URL=https://votre-projet.supabase.co
# Clé publique publishable (ou anon legacy). Ne jamais utiliser service_role ici.
VITE_SUPABASE_ANON_KEY=votre_cle_publique
# Facultatif : URL publique finale, utilisée pour les liens de partage
VITE_PUBLIC_APP_URL=https://publia.app
